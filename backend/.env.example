# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/library?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY_HOURS=24

# Email domain restriction
ALLOWED_EMAIL_DOMAIN=slu.edu
# Comma-separated list of emails that become admins on first registration
ADMIN_EMAILS=admin@slu.edu

# SMTP (Outlook)
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=MDH1056LibrarySystem@outlook.com
MAIL_PASSWORD=your-outlook-password
MAIL_FROM=MDH1056LibrarySystem@outlook.com

# Frontend URL (used in verification email links)
FRONTEND_URL=http://localhost:5173

# CORS (React dev server)
CORS_ORIGIN=http://localhost:5173
